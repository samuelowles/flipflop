{
  "name": "flip-workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "migrate:local": "wrangler d1 execute flip-db --local --file",
    "migrate:remote": "wrangler d1 execute flip-db --remote --file",
    "test-run:reset": "node ../scripts/test-run-reset.mjs"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.7.0",
    "@cloudflare/workers-types": "^4.20250514.0",
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "3.0.9",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.91.0"
  }
}
